### =====================================
### 🌍 ENVIRONMENT VARIABLES
### =====================================

@local = http://localhost:3000
@render = https://your-app-name.onrender.com


### =====================================
### 🔹 STUDENTS (LOCALHOST)
### =====================================

### Create Student
POST {{local}}/students
Content-Type: application/json

{
  "firstName": "Test",
  "lastName": "Student",
  "email": "test@student.com",
  "age": 22,
  "course": "Computer Science",
  "gpa": 3.5,
  "enrollmentDate": "2024-01-01"
}

###

### Get All Students
GET {{local}}/students

###

### Get Single Student
GET {{local}}/students/PUT_STUDENT_ID_HERE

###

### Update Student
PUT {{local}}/students/PUT_STUDENT_ID_HERE
Content-Type: application/json

{
  "firstName": "Updated",
  "lastName": "Student",
  "email": "updated@student.com",
  "age": 25,
  "course": "Software Engineering",
  "gpa": 3.9,
  "enrollmentDate": "2024-01-01"
}

###

### Delete Student
DELETE {{local}}/students/PUT_STUDENT_ID_HERE

###



### =====================================
### 🔹 COURSES (LOCALHOST)
### =====================================

### Create Course
POST {{local}}/courses
Content-Type: application/json

{
  "courseName": "Web Development",
  "courseCode": "CSE341",
  "instructor": "Dr Smith",
  "credits": 3
}

###

### Get All Courses
GET {{local}}/courses

###

### Get Single Course
GET {{local}}/courses/PUT_COURSE_ID_HERE

###

### Update Course
PUT {{local}}/courses/PUT_COURSE_ID_HERE
Content-Type: application/json

{
  "courseName": "Advanced Web Dev",
  "courseCode": "CSE341",
  "instructor": "Dr John",
  "credits": 4
}

###

### Delete Course
DELETE {{local}}/courses/PUT_COURSE_ID_HERE

###



